{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "test:dice": "node --test resources/js/lib/dice.test.mjs",
        "typecheck": "vue-tsc --noEmit",
        "test:e2e": "playwright test",
        "scrape": "node scripts/scrape-spells.mjs",
        "analyse": "ddev exec vendor/bin/phpstan analyse --memory-limit=1G",
        "test:scripts": "node --test 'scripts/*.test.mjs'"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.8",
        "@vue/tsconfig": "^0.9.1",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "node-html-parser": "^9.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "vue-tsc": "^3.3.7"
    },
    "dependencies": {
        "@inertiajs/vue3": "^3.6.1",
        "pinia": "^4.0.2",
        "vue": "^3.5.40"
    }
}
