#!/usr/bin/env php
<?php

declare(strict_types=1);

$projectRoot = dirname(__DIR__);
if (! is_dir($projectRoot.'/tests')) {
    $vendorDirectory = realpath($projectRoot.'/vendor');
    if ($vendorDirectory !== false && is_dir(dirname($vendorDirectory).'/tests')) {
        $projectRoot = dirname($vendorDirectory);
    }
}
if (! chdir($projectRoot)) {
    fwrite(STDERR, "Unable to run Pest from project root {$projectRoot}.\n");

    exit(1);
}
$versionRequested = in_array('--version', $argv, true);
$runner = $versionRequested
    ? $projectRoot.'/vendor/bin/phpunit'
    : $projectRoot.'/vendor/bin/pest';
$command = escapeshellarg(PHP_BINARY).' '.escapeshellarg($runner);
$junitPath = null;
$arguments = array_slice($argv, 1);
foreach ($arguments as $index => $argument) {
    if (is_file($argument) || ! preg_match('#/tests/(.+)$#', $argument, $matches)) {
        continue;
    }

    $projectTestPath = $projectRoot.'/tests/'.$matches[1];
    if (is_file($projectTestPath)) {
        $arguments[$index] = $projectTestPath;
    }
}
for ($index = 0; $index < count($arguments) - 1; $index++) {
    if ($arguments[$index] === '--configuration') {
        relocateTestSuitePaths($arguments[$index + 1], $projectRoot);
    }

    if ($arguments[$index] === '--filter') {
        $arguments[$index + 1] = pestFilterForInfection($arguments[$index + 1]);
    }
}

foreach ($arguments as $argument) {
    $command .= ' '.escapeshellarg($argument);

    if (str_starts_with($argument, '--log-junit=')) {
        $junitPath = substr($argument, strlen('--log-junit='));
    }
}

passthru($command, $exitCode);

if (! $versionRequested && $exitCode === 0) {
    if ($junitPath !== null && is_file($junitPath)) {
        $document = new DOMDocument;
        $document->load($junitPath);
        $xpath = new DOMXPath($document);

        foreach (['//testsuite/@name', '//testcase/@class'] as $query) {
            foreach ($xpath->query($query) ?: [] as $attribute) {
                if (str_starts_with($attribute->nodeValue, 'Tests\\')) {
                    $attribute->nodeValue = 'P\\'.$attribute->nodeValue;
                }
            }
        }

        $document->save($junitPath);
    }

    echo "OK (Pest suite)\n";
}

exit($exitCode);

function pestFilterForInfection(string $filter): string
{
    preg_match_all('/__pest_evaluable_([A-Za-z0-9_]+)/', $filter, $matches);
    $methods = array_values(array_unique($matches[1] ?? []));
    if ($methods === []) {
        return $filter;
    }

    $descriptions = array_map(static function (string $method): string {
        $stablePrefix = explode('__', $method, 2)[0];
        $words = array_values(array_filter(explode('_', $stablePrefix)));

        return implode('[^A-Za-z0-9]+', array_map(
            static fn (string $word): string => preg_quote($word, '/'),
            $words,
        ));
    }, $methods);

    return '/'.implode('|', $descriptions).'/';
}

function relocateTestSuitePaths(string $configurationPath, string $projectRoot): void
{
    if (! is_file($configurationPath)) {
        return;
    }

    $document = new DOMDocument;
    $document->load($configurationPath);
    $xpath = new DOMXPath($document);
    $changed = false;

    foreach ($xpath->query('//testsuites//file | //testsuites//directory') ?: [] as $node) {
        $relativePath = trim($node->textContent);
        if ($relativePath === '' || str_starts_with($relativePath, '/')) {
            continue;
        }

        $projectPath = $projectRoot.'/'.$relativePath;
        if (file_exists($projectPath)) {
            $node->textContent = $projectPath;
            $changed = true;
        }
    }

    if ($changed) {
        $document->save($configurationPath);
    }
}
