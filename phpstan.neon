includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 8

    # Level 10 currently reports 454 errors (down from 549). Most remaining
    # findings are mixed values at the raw query/JSON boundaries; finish the
    # per-builder row hydration incrementally rather than suppressing them.

    paths:
        - app
        - database/seeders
        - config

    treatPhpDocTypesAsCertain: false
